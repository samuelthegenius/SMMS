# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your_supabase_anon_key_here

# AI Services (Server-side only - DO NOT commit)
GEMINI_API_KEY=your_gemini_api_key_here

# Email Service (Server-side only - DO NOT commit)
EMAILJS_SERVICE_ID=your_emailjs_service_id
EMAILJS_TEMPLATE_ID=your_emailjs_template_id
EMAILJS_USER_ID=your_emailjs_public_key
EMAILJS_PRIVATE_KEY=your_emailjs_private_key

# Staff/Technician Registration Secrets (Store securely in Supabase Dashboard)
# These should be generated using: openssl rand -hex 16
STAFF_SECRET_KEY=CHANGE_THIS_IN_SUPABASE_CONFIG
TECHNICIAN_SECRET_KEY=CHANGE_THIS_IN_SUPABASE_CONFIG
