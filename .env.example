# ============================================================================
# SMMS Environment Variables Template
# ============================================================================
# Copy this file to .env and fill in your values
# 
# SERVER-SIDE SECRETS: Do NOT add sensitive keys here!
# Set those in Vercel Dashboard > Project Settings > Environment Variables
# ============================================================================

# Supabase (Safe for client - these are public by design)
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your_supabase_anon_key_here

# ============================================================================
# VERCEL PLATFORM - Set in Vercel Dashboard, NOT in code!
# ============================================================================

# AI Gateway (required for AI features)
# Get from: https://vercel.com/dashboard/ai-gateway
AI_GATEWAY_API_KEY=your_ai_gateway_key_here

# Vercel Blob (required for file uploads)
# Automatically set when you add Blob to your project
BLOB_READ_WRITE_TOKEN=your_blob_token_here

# Vercel Edge Config (optional, for global settings)
# Get from: https://vercel.com/dashboard/stores/edge-config
EDGE_CONFIG=your_edge_config_connection_string_here

# Cron Secret (for securing cron job endpoints)
# Generate a random string: openssl rand -base64 32
CRON_SECRET=your_cron_secret_here

# OpenTelemetry (optional)
# OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp.vercel.sh
# OTEL_EXPORTER_OTLP_HEADERS=x-vercel-otel-key=your_key_here

# ============================================================================
# SUPABASE SERVER-SIDE SECRETS - Set in Supabase Dashboard if using Edge Functions
# Navigate to: Edge Functions > Secrets > New Secret
# 
# Required secrets:
# - GEMINI_API_KEY
# - EMAILJS_SERVICE_ID
# - EMAILJS_TEMPLATE_ID
# - EMAILJS_USER_ID
# - EMAILJS_PRIVATE_KEY
# - ADMIN_EMAIL
# - DASHBOARD_URL
# - SUPABASE_SERVICE_ROLE_KEY (if using server-side Supabase)
#
# See SECURITY.md for setup instructions
# ============================================================================
