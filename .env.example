# ============================================================================
# SMMS Environment Variables Template
# ============================================================================
# Copy this file to .env and fill in your values
# ============================================================================

# Supabase (Safe for client - these are public by design)
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your_supabase_anon_key_here

# ============================================================================
# SERVER-SIDE SECRETS - Set in your hosting environment (not in code!)
# ============================================================================

# Supabase service role key (for server-side API routes like /api/auth/register)
# Get from: Supabase Dashboard > Project Settings > API
SUPABASE_URL=your_supabase_url_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Production app URL (for CORS allowlist)
PUBLIC_APP_URL=https://your-domain.com

# ============================================================================
# SUPABASE EDGE FUNCTION SECRETS
# Navigate to: Supabase Dashboard > Edge Functions > Secrets > New Secret
#
# Required secrets:
# - GEMINI_API_KEY          (for AI categorization and fix suggestions)
# - EMAILJS_SERVICE_ID      (for email notifications)
# - EMAILJS_TEMPLATE_ID
# - EMAILJS_USER_ID
# - EMAILJS_PRIVATE_KEY
# - ADMIN_EMAIL
# - DASHBOARD_URL
# - SUPABASE_SERVICE_ROLE_KEY
#
# See SECURITY.md for setup instructions
# ============================================================================
