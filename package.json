{
  "name": "smms",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:vercel": "vercel dev --listen 3000",
    "check:vercel-routing": "node scripts/validate-vercel-routing.cjs",
    "prebuild": "npm run check:vercel-routing",
    "build": "vite build",
    "build:analyze": "vite build --mode analyze",
    "build:profile": "npm run build && npm run preview",
    "preview": "vite preview",
    "lint": "eslint .",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "security:scan": "node scripts/simple-security-scan.cjs",
    "security:audit": "npm audit --audit-level=moderate",
    "security:all": "npm run security:audit && npm run security:scan"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^0.2.0",
    "@supabase/supabase-js": "^2.87.1",
    "@vercel/blob": "^2.3.1",
    "@vercel/functions": "^2.0.0",
    "ai": "^6.0.140",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.2",
    "lucide-react": "^0.561.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^8.0.0",
    "react-router-dom": "^7.10.1",
    "recharts": "^3.6.0",
    "sonner": "^2.0.7",
    "swr": "^2.3.8",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^26.0.0",
    "postcss": "^8.5.10",
    "rollup-plugin-visualizer": "^5.12.0",
    "sharp": "^0.34.5",
    "tailwindcss": "3.4.14",
    "terser": "^5.46.1",
    "vite": "^7.2.4",
    "vitest": "^3.0.0"
  }
}
